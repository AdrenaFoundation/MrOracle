# MrOracle — devnet configuration
# Loaded via dotenvy. CLI args override where applicable.

RUST_LOG=info
DRY_RUN=false
MAIN_POOL_ID=<your-devnet-pool-pda>

# Feed map paths (relative to MrOracle working directory)
CHAOSLABS_FEED_MAP_PATH=config/chaoslabs_feed_map.json
AUTONOM_FEED_MAP_PATH=config/autonom_feed_map.json
SWITCHBOARD_FEED_MAP_PATH=config/switchboard_feed_map.json

# ── CLI args (not loaded from .env) ──

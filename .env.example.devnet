# MrOracle release/39 — DEVNET example
#
# Assumes:
#  - The adrena program is deployed on devnet at 13gDzEXCdocbj8iAiqrScGo47NiSuYENGsRqi3SEAwet
#  - adrena-data/cron's 4 new processors are writing to a shared Postgres
#    (with the oracle-batches migration applied)
#  - ops has generated a combined TLS cert for the Postgres connection
#  - pools_config.json has devnet pool/custody pubkeys substituted in

SOLANA_RPC_DEVNET="https://api.devnet.solana.com"
SOLANA_RPC_BACKUP="https://devnet.helius-rpc.com/?api-key=…"
PAYER_KEYPAIR_PATH="/home/botvenom/.config/solana/deployer.json"

DB_STRING="host=… port=5432 user=adrena dbname=adrena_data sslmode=require"
COMBINED_CERT_PATH="/etc/ssl/certs/combined.pem"

CHAOSLABS_POLL_MS=400
AUTONOM_POLL_MS=2000
SWITCHBOARD_POLL_MS=2000

# Devnet Switchboard queue (Queue.DEFAULT_DEVNET_KEY in the on-demand SDK)
SWITCHBOARD_QUEUE_PUBKEY="EYiAmGSdsQTuCw413V5BzaruWuCCSDgTPtBGvLkXHbe7"
SWITCHBOARD_MAX_AGE_SLOTS=150
SWITCHBOARD_FEED_MAP_PATH="config/switchboard_feed_map_devnet.json"

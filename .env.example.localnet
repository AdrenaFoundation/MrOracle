# MrOracle release/39 — LOCALNET example
#
# Assumes a local solana-test-validator + a local Postgres with
# adrena-data/cron/db/migration/oracle-batches/migration-oracle-batches.sql applied.

SOLANA_RPC_LOCALNET="http://127.0.0.1:8899"
PAYER_KEYPAIR_PATH="/home/botvenom/.config/solana/id.json"
DB_STRING="host=localhost port=5432 user=botvenom dbname=adrena_data"
COMBINED_CERT_PATH="/tmp/dummy.pem"

CHAOSLABS_POLL_MS=400
AUTONOM_POLL_MS=2000
SWITCHBOARD_POLL_MS=2000
SWITCHBOARD_MAX_AGE_SLOTS=150
